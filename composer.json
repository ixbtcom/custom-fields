{
    "name": "aureuserp/custom-fields",
    "description": "A Filament v5 plugin that lets end-users add dynamic custom fields to any Eloquent model + Filament resource at runtime.",
    "keywords": [
        "webkul",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "custom-fields",
        "dynamic-fields"
    ],
    "homepage": "https://github.com/aureuserp/custom-fields",
    "license": "MIT",
    "authors": [
        {
            "name": "Webkul",
            "email": "support@webkul.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "filament/forms": "^5.0",
        "filament/infolists": "^5.0",
        "filament/tables": "^5.0",
        "spatie/eloquent-sortable": "^4.0|^5.0",
        "spatie/laravel-package-tools": "^1.15"
    },
    "autoload": {
        "psr-4": {
            "Webkul\\CustomFields\\": "src/",
            "Webkul\\CustomFields\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webkul\\CustomFields\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webkul\\CustomFields\\CustomFieldsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
